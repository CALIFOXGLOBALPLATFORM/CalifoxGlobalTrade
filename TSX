const register = useCallback((name: string, email: string, password: string, plan: string) => {
  const users = loadUsers();
  if (users.find(u => u.email.toLowerCase() === email.toLowerCase())) return false;
  
  const newUser: AuthUser = {
    id: Math.random().toString(36).slice(2),
    name, 
    email, 
    passwordHash: simpleHash(password), 
    plan,
    balance: 0,
    transactions: [],
    role: 'user',
    joinedAt: new Date().toISOString()
  };
  
  saveUsers([...users, newUser]);
  sessionStorage.setItem(SESSION_KEY, newUser.id);
  setUser(newUser);

  // === WELCOME MESSAGE FOR NEW USER ===
  pushNotification({ 
    type: "info", 
    title: "🎉 Welcome to Califox Global!", 
    message: `Dear ${name}, your ${plan} account is now active. Your dedicated manager will contact you shortly.` 
  });

  // === NOTIFY ADMIN ===
  const admin = users.find(u => u.role === 'admin');
  if (admin) {
    pushNotification({ 
      type: "info", 
      title: "🔔 New User Registered", 
      message: `\( {name} ( \){email}) joined with ${plan} Plan` 
    });
  }

  // Simulate welcome email
  console.log(`📧 [EMAIL] Welcome to \( {name} < \){email}> - Account Created`);

  return true;
}, [pushNotification]);